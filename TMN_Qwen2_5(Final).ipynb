        "# Section 6: Evaluation & Visualization\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.font_manager as fm\n",
        "import seaborn as sns\n",
        "from sklearn.metrics import (\n",
        "    confusion_matrix, accuracy_score, fbeta_score,\n",
        "    f1_score, classification_report, precision_recall_fscore_support,\n",
        ")\n",
        "\n",
        "plt.style.use('seaborn-v0_8-whitegrid')\n",
        "plt.rcParams['figure.dpi'] = 120\n",
        "\n",
        "LABEL_EN = {\n",
        "    \"ช้อปปิ้ง\":             \"Shopping\",\n",
        "    \"ท่องเที่ยว\":           \"Travel\",\n",
        "    \"บริการต่างๆ\":          \"Services\",\n",
        "    \"บันเทิง\":              \"Entertainment\",\n",
        "    \"สุขภาพและความงาม\":     \"Health & Beauty\",\n",
        "    \"อาหารและเครื่องดื่ม\":  \"Food & Beverage\",\n",
        "}\n",
        "\n",
        "# --- Prepare ---\n",
        "eval_df = result_df.dropna(subset=['TrueCategory', 'Pred_Category']).copy()\n",
        "y_true  = eval_df['TrueCategory']\n",
        "y_pred  = eval_df['Pred_Category']\n",
        "labels     = sorted(list(set(y_true) | set(y_pred)))\n",
        "labels_en  = [LABEL_EN.get(l, l) for l in labels]\n",
        "\n",
        "print(\"=\" * 60)\n",
        "print(f\"{'MODEL PERFORMANCE EVALUATION REPORT':^60}\")\n",
        "print(\"=\" * 60)\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# PART 1: Executive Summary\n",
        "# ----------------------------------------------------------\n",
        "acc         = accuracy_score(y_true, y_pred)\n",
        "macro_f1    = f1_score(y_true, y_pred, average='macro',    zero_division=0)\n",
        "weighted_f1 = f1_score(y_true, y_pred, average='weighted', zero_division=0)\n",
        "macro_f2    = fbeta_score(y_true, y_pred, beta=2, average='macro',    zero_division=0)\n",
        "weighted_f2 = fbeta_score(y_true, y_pred, beta=2, average='weighted', zero_division=0)\n",
        "\n",
        "print(f\"\\n1. EXECUTIVE SUMMARY\")\n",
        "print(f\"{'-' * 45}\")\n",
        "print(f\"  Total Samples Evaluated : {len(y_true)}\")\n",
        "print(f\"  Global Accuracy         : {acc:.2%}\")\n",
        "print(f\"  Macro F1-Score          : {macro_f1:.4f}\")\n",
        "print(f\"  Macro F2-Score          : {macro_f2:.4f}\")\n",
        "print(f\"  Weighted F1-Score       : {weighted_f1:.4f}\")\n",
        "print(f\"  Weighted F2-Score       : {weighted_f2:.4f}\")\n",
        "print(f\"{'-' * 45}\")\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# PART 2: Confusion Matrix + Metrics per Category\n",
        "# ----------------------------------------------------------\n",
        "fig, ax = plt.subplots(1, 2, figsize=(18, 7))\n",
        "\n",
        "cm      = confusion_matrix(y_true, y_pred, labels=labels)\n",
        "cm_norm = confusion_matrix(y_true, y_pred, labels=labels, normalize='true')\n",
        "\n",
        "annot = [\n",
        "    [f\"{count}\\n({percent:.1%})\" for count, percent in zip(row_c, row_p)]\n",
        "    for row_c, row_p in zip(cm, cm_norm)\n",
        "]\n",
        "\n",
        "sns.heatmap(cm_norm, annot=annot, fmt='', cmap='Blues',\n",
        "            xticklabels=labels_en, yticklabels=labels_en,\n",
        "            cbar_kws={'label': 'Proportion Correct'}, ax=ax[0], square=True)\n",
        "ax[0].set_title(\"Confusion Matrix (Normalized)\", fontsize=14, fontweight='bold')\n",
        "ax[0].set_ylabel('Actual Category', fontsize=12)\n",
        "ax[0].set_xlabel('Predicted Category', fontsize=12)\n",
        "ax[0].tick_params(axis='x', rotation=45)\n",
        "ax[0].tick_params(axis='y', rotation=0)\n",
        "\n",
        "precision, recall, f1, _ = precision_recall_fscore_support(\n",
        "    y_true, y_pred, labels=labels, zero_division=0\n",
        ")\n",
        "x     = np.arange(len(labels_en))\n",
        "width = 0.25\n",
        "ax[1].bar(x - width, precision, width, label='Precision', color='#a8dadc')\n",
        "ax[1].bar(x,         recall,    width, label='Recall',    color='#457b9d')\n",
        "ax[1].bar(x + width, f1,        width, label='F1-Score',  color='#1d3557')\n",
        "ax[1].set_title(\"Performance Metrics by Category\", fontsize=14, fontweight='bold')\n",
        "ax[1].set_xticks(x)\n",
        "ax[1].set_xticklabels(labels_en, rotation=45, ha='right')\n",
        "ax[1].set_ylim(0, 1.1)\n",
        "ax[1].legend(loc='lower left')\n",
        "ax[1].grid(axis='y', linestyle='--', alpha=0.7)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig('metrics_by_category.png', dpi=300)\n",
        "plt.show()\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# PART 3: Misclassification Analysis\n",
        "# ----------------------------------------------------------\n",
        "print(\"\\n2. TOP CONFUSED PAIRS\")\n",
        "print(f\"{'-' * 75}\")\n",
        "print(f\"{'Actual Category':<25} | {'Predicted (Wrongly)':<25} | {'Count':<10}\")\n",
        "print(f\"{'-' * 75}\")\n",
        "\n",
        "confused_pairs = [\n",
        "    (cm[i, j], true_l, pred_l)\n",
        "    for i, true_l in enumerate(labels)\n",
        "    for j, pred_l in enumerate(labels)\n",
        "    if i != j and cm[i, j] > 0\n",
        "]\n",
        "confused_pairs.sort(key=lambda x: x[0], reverse=True)\n",
        "\n",
        "if not confused_pairs:\n",
        "    print(f\"{'No errors found! Perfect classification.':^75}\")\n",
        "else:\n",
        "    for count, true_l, pred_l in confused_pairs[:5]:\n",
        "        print(f\"{LABEL_EN.get(true_l, true_l):<25} > {LABEL_EN.get(pred_l, pred_l):<25} : {count} cases\")\n",
        "\n",
        "print(\"\\n3. Classification Report:\")\n",
        "y_true_en = y_true.map(lambda x: LABEL_EN.get(x, x))\n",
        "y_pred_en = y_pred.map(lambda x: LABEL_EN.get(x, x))\n",
        "print(classification_report(y_true_en, y_pred_en, zero_division=0))\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# PART 4: Confidence Score Distribution\n",
        "# ----------------------------------------------------------\n",
        "conf_df = eval_df.dropna(subset=['Confidence']).copy()\n",
        "conf_df['Correct'] = conf_df['TrueCategory'] == conf_df['Pred_Category']\n",
        "\n",
        "correct_conf = conf_df[conf_df['Correct']]['Confidence']\n",
        "wrong_conf   = conf_df[~conf_df['Correct']]['Confidence']\n",
        "overall_mean = conf_df['Confidence'].mean()\n",
        "overall_med  = conf_df['Confidence'].median()\n",
        "\n",
        "fig, axes = plt.subplots(1, 3, figsize=(20, 6))\n",
        "fig.suptitle(\n",
        "    'Confidence Score Analysis (Qwen2.5-VL — Candidate Log-Prob Scoring)',\n",
        "    fontsize=15, fontweight='bold', y=1.02,\n",
        ")\n",
        "\n",
        "# Plot 1: Overall Distribution\n",
        "axes[0].hist(conf_df['Confidence'], bins=25,\n",
        "             color='#457b9d', edgecolor='white', linewidth=0.5)\n",
        "axes[0].axvline(overall_mean, color='#e63946', linestyle='--', linewidth=1.8,\n",
        "                label=f'Mean   : {overall_mean:.3f}')\n",
        "axes[0].axvline(overall_med,  color='#f4a261', linestyle=':',  linewidth=1.8,\n",
        "                label=f'Median : {overall_med:.3f}')\n",
        "axes[0].set_title('Overall Confidence Distribution', fontweight='bold')\n",
        "axes[0].set_xlabel('Confidence Score')\n",
        "axes[0].set_ylabel('Number of Shops')\n",
        "axes[0].set_xlim(0, 1)\n",
        "axes[0].legend(fontsize=10)\n",
        "\n",
        "stats_text = (\n",
        "    f\"n    = {len(conf_df)}\\n\"\n",
        "    f\"Std  = {conf_df['Confidence'].std():.3f}\\n\"\n",
        "    f\"Min  = {conf_df['Confidence'].min():.3f}\\n\"\n",
        "    f\"Max  = {conf_df['Confidence'].max():.3f}\"\n",
        ")\n",
        "axes[0].text(0.03, 0.97, stats_text, transform=axes[0].transAxes,\n",
        "             verticalalignment='top', fontsize=9,\n",
        "             bbox=dict(boxstyle='round', facecolor='white', alpha=0.7))\n",
        "\n",
        "# Plot 2: Correct vs Wrong\n",
        "bins = np.linspace(0, 1, 26)\n",
        "axes[1].hist(correct_conf, bins=bins, alpha=0.65, color='#2ecc71', edgecolor='white',\n",
        "             label=f'Correct (n={len(correct_conf)}, μ={correct_conf.mean():.3f})')\n",
        "axes[1].hist(wrong_conf,   bins=bins, alpha=0.65, color='#e74c3c', edgecolor='white',\n",
        "             label=f'Wrong   (n={len(wrong_conf)}, μ={wrong_conf.mean():.3f})')\n",
        "axes[1].axvline(correct_conf.mean(), color='#27ae60', linestyle='--', linewidth=1.5)\n",
        "axes[1].axvline(wrong_conf.mean(),   color='#c0392b', linestyle='--', linewidth=1.5)\n",
        "axes[1].set_title('Confidence: Correct vs Wrong Predictions', fontweight='bold')\n",
        "axes[1].set_xlabel('Confidence Score')\n",
        "axes[1].set_ylabel('Number of Shops')\n",
        "axes[1].set_xlim(0, 1)\n",
        "axes[1].legend(fontsize=10)\n",
        "\n",
        "# Plot 3: Mean Confidence by True Category\n",
        "cat_conf = (\n",
        "    conf_df.groupby('TrueCategory')['Confidence']\n",
        "    .agg(['mean', 'std', 'count'])\n",
        "    .sort_values('mean')\n",
        ")\n",
        "cat_conf.index = [LABEL_EN.get(l, l) for l in cat_conf.index]\n",
        "\n",
        "y_pos = np.arange(len(cat_conf))\n",
        "bars  = axes[2].barh(\n",
        "    y_pos, cat_conf['mean'], xerr=cat_conf['std'],\n",
        "    color='#a8dadc', edgecolor='#457b9d',\n",
