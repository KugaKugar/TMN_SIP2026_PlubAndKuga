      "source": [
        "# Section 7: Alternate Evaluation (Binary: Match vs Mismatch)\n",
        "from sklearn.metrics import accuracy_score, fbeta_score, f1_score, classification_report\n",
        "\n",
        "eval_df['Actual_Mismatch']     = eval_df['Category'] != eval_df['TrueCategory']\n",
        "eval_df['AI_Flagged_Mismatch'] = eval_df['Category'] != eval_df['Pred_Category']\n",
        "\n",
        "y_true_b = eval_df['Actual_Mismatch'].astype(int)\n",
        "y_pred_b  = eval_df['AI_Flagged_Mismatch'].astype(int)\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# PART 1: Confusion Matrix (Fraud Detection — 2x2)\n",
        "# ----------------------------------------------------------\n",
        "cm_binary   = confusion_matrix(y_true_b, y_pred_b)\n",
        "class_names = ['Match\\n(Normal)', 'Mismatch\\n(Fraud/Error)']\n",
        "\n",
        "plt.figure(figsize=(8, 6))\n",
        "sns.heatmap(cm_binary, annot=True, fmt='g', cmap='Blues',\n",
        "            xticklabels=class_names, yticklabels=class_names,\n",
        "            cbar_kws={'label': 'Number of Shops'},\n",
        "            linewidths=1, linecolor='black',\n",
        "            annot_kws={\"size\": 16, \"weight\": \"bold\"})\n",
        "plt.title('AI Merchant Categorization: Fraud Detection (Qwen2.5-VL)',\n",
        "          fontsize=16, fontweight='bold', pad=20)\n",
        "plt.ylabel('Actual (Ground Truth)', fontsize=14, fontweight='bold')\n",
        "plt.xlabel('AI Decision (Prediction)', fontsize=14, fontweight='bold')\n",
        "plt.yticks(rotation=0)\n",
        "plt.tight_layout()\n",
        "plt.savefig('confusion_matrix_report.png', dpi=300)\n",
        "plt.show()\n",
        "\n",
        "# ----------------------------------------------------------\n",
        "# PART 2: Executive Summary (Binary)\n",
        "# ----------------------------------------------------------\n",
        "accuracy_b    = accuracy_score(y_true_b, y_pred_b)\n",
        "weighted_f1_b = f1_score(y_true_b, y_pred_b, average='weighted', zero_division=0)\n",
        "weighted_f2_b = fbeta_score(y_true_b, y_pred_b, beta=2, average='weighted', zero_division=0)\n",
        "\n",
        "print(\"\\n\" + \"=\" * 50)\n",
        "print(f\"{'Model Performance Evaluation (Qwen2.5-VL)':^50}\")\n",
        "print(\"=\" * 50)\n",
        "print(f\"  Total Samples Evaluated : {len(eval_df)}\")\n",
        "print(f\"  Global Accuracy         : {accuracy_b:.2%}\")\n",
        "print(f\"  Weighted F1-Score       : {weighted_f1_b:.4f}\")\n",
        "print(f\"  Weighted F2-Score       : {weighted_f2_b:.4f}\")\n",
        "print(\"=\" * 50)\n",
        "\n",
        "print(\"\\nClassification Report (Match vs Mismatch):\")\n",
        "print(classification_report(y_true_b, y_pred_b,\n",
        "                             target_names=['Match', 'Mismatch'],\n",
        "                             zero_division=0))"
