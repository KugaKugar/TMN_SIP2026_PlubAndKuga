    {
      "cell_type": "code",
      "source": [
        "#Section 4: Image Utility\n",
        "from PIL import Image\n",
        "import numpy as np\n",
        "import torch.nn.functional as F\n",
        "\n",
        "\n",
        "def get_shop_images(shop_id, base_path):\n",
        "    \"\"\"ค้นหา image files ของ shop_id จาก directory\"\"\"\n",
        "    shop_dir = os.path.join(base_path, str(shop_id))\n",
        "\n",
        "    if not os.path.exists(shop_dir):\n",
        "        for root, dirs, files in os.walk(base_path):\n",
        "            if str(shop_id) in dirs:\n",
        "                shop_dir = os.path.join(root, str(shop_id))\n",
        "                break\n",
        "\n",
        "    if os.path.exists(shop_dir):\n",
        "        exts = ('.png', '.jpg', '.jpeg')\n",
        "        return [\n",
        "            os.path.join(shop_dir, f)\n",
        "            for f in os.listdir(shop_dir)\n",
        "            if f.lower().endswith(exts)\n",
        "        ]\n",
        "    return []\n",
        "\n",
        "\n",
        "def create_image_grid(image_paths, max_images=4):\n",
        "    \"\"\"รวมภาพหลายใบเป็น grid เดียว (สูงสุด max_images ภาพ)\"\"\"\n",
        "    images = []\n",
        "    for path in image_paths[:max_images]:\n",
        "        try:\n",
        "            img = Image.open(path).convert(\"RGB\")\n",
        "            img.thumbnail((512, 512))\n",
        "            images.append(img)\n",
        "        except Exception as e:\n",
        "            print(f\"  [Warning] Error loading {path}: {e}\")\n",
        "\n",
        "    if not images:\n",
        "        return None\n",
        "\n",
        "    n      = len(images)\n",
        "    cols   = 2 if n > 1 else 1\n",
        "    rows   = (n + 1) // 2\n",
        "    w, h   = images[0].size\n",
        "    grid   = Image.new('RGB', (w * cols, h * rows))\n",
        "\n",
        "    for i, img in enumerate(images):\n",
        "        r, c = i // cols, i % cols\n",
        "        grid.paste(img.resize((w, h)), (c * w, r * h))\n",
        "\n",
        "    return grid\n",
        "\n",
        "\n",
        "# --- Candidate Scoring for Confidence ---\n",
        "CATEGORIES = [\n",
        "    \"ช้อปปิ้ง\",\n",
        "    \"อาหารและเครื่องดื่ม\",\n",
        "    \"บริการต่างๆ\",\n",
        "    \"ท่องเที่ยว\",\n",
        "    \"สุขภาพและความงาม\",\n",
        "    \"บันเทิง\",\n",
        "]\n",
        "\n",
        "\n",
        "def compute_category_confidence(model, processor, messages, image_inputs,\n",
        "                                categories=CATEGORIES):\n",
        "    \"\"\"\n",
        "    คำนวณ confidence score โดยวิธี Candidate Log-Probability Scoring:\n",
        "      1. สร้าง candidate JSON string ของแต่ละ category\n",
        "      2. คำนวณ mean log-probability (length-normalized) ของแต่ละ candidate\n",
        "         ผ่าน forward pass โดยไม่ generate ใหม่ (เร็วและแม่นยำกว่า)\n",
        "      3. Softmax → probability distribution [0, 1] ที่ไม่ overconfident\n",
        "\n",
        "    Args:\n",
        "        model, processor : Qwen2.5-VL model และ processor\n",
        "        messages         : list of message dicts (เหมือนที่ใช้ใน generation)\n",
        "        image_inputs     : image tensors จาก process_vision_info()\n",
        "        categories       : list of candidate category strings\n",
        "\n",
        "    Returns:\n",
        "        probs      (np.ndarray) : softmax probability แต่ละ category, shape (6,)\n",
        "        best_cat   (str)        : category ที่ได้ probability สูงสุด\n",
        "        confidence (float)      : max probability [0, 1]\n",
        "    \"\"\"\n",
        "    base_text  = processor.apply_chat_template(\n",
        "        messages, tokenize=False, add_generation_prompt=True\n",
        "    )\n",
        "    base_inputs = processor(\n",
        "        text=[base_text],\n",
        "        images=image_inputs,\n",
        "        videos=None,\n",
        "        padding=False,\n",
        "        return_tensors=\"pt\",\n",
        "    ).to(\"cuda\")\n",
        "    prefix_len = base_inputs.input_ids.shape[1]\n",
        "\n",
        "    log_scores = []\n",
        "\n",
        "    for cat in categories:\n",
        "        candidate_str = f'{{\"Predicted_Category\": \"{cat}\"}}'\n",
        "        full_text     = base_text + candidate_str\n",
        "\n",
        "        full_inputs = processor(\n",
        "            text=[full_text],\n",
        "            images=image_inputs,\n",
        "            videos=None,\n",
        "            padding=False,\n",
        "            return_tensors=\"pt\",\n",
        "        ).to(\"cuda\")\n",
        "\n",
        "        cand_ids = full_inputs.input_ids[0, prefix_len:]\n",
        "\n",
        "        if len(cand_ids) == 0:\n",
        "            log_scores.append(-1e9)\n",
        "            continue\n",
        "\n",
        "        with torch.no_grad():\n",
        "            outputs   = model(**full_inputs)\n",
        "            logits    = outputs.logits[0]                          # (seq_len, vocab_size)\n",
        "\n",
        "        # logit ตำแหน่ง t-1 ทำนาย token ตำแหน่ง t\n",
        "        cand_logits = logits[prefix_len - 1 : prefix_len - 1 + len(cand_ids)]\n",
        "        log_probs   = F.log_softmax(cand_logits, dim=-1)\n",
        "        token_lp    = log_probs[torch.arange(len(cand_ids)), cand_ids]\n",
        "\n",
        "        # Mean log-prob (length-normalized)\n",
        "        log_scores.append(token_lp.mean().item())\n",
        "\n",
        "    probs      = F.softmax(torch.tensor(log_scores, dtype=torch.float32), dim=0).numpy()\n",
        "    best_idx   = int(probs.argmax())\n",
        "    best_cat   = categories[best_idx]\n",
        "    confidence = float(probs[best_idx])\n",
        "\n",
        "    return probs, best_cat, confidence"
      ],
