      "cell_type": "code",
      "source": [
        "#Section 5: Run Prediction Pipeline\n",
        "from qwen_vl_utils import process_vision_info\n",
        "import re\n",
        "\n",
        "# --- Prompt Template ---\n",
        "system_prompt = \"\"\"\n",
        "คุณเป็น AI ผู้เชี่ยวชาญด้านการจำแนกประเภทธุรกิจ (Merchant Categorization) ที่มีความแม่นยำสูง\n",
        "หน้าที่ของคุณคือวิเคราะห์ \"รูปภาพ\" (ซึ่งอาจเป็นหน้าร้านจริง, ภายในร้าน, หรือภาพแคปหน้าจอจาก Facebook/Line/Online Shop) เพื่อระบุ Category ที่ถูกต้องที่สุด\n",
        "\n",
        "**ชุดข้อมูลหมวดหมู่ (Taxonomy):**\n",
        "คุณต้องเลือกตอบเพียง 1 หมวดหมู่ จาก 6 ตัวเลือกนี้เท่านั้น (ห้ามตอบอื่นนอกจากนี้):\n",
        "1. ช้อปปิ้ง\n",
        "2. อาหารและเครื่องดื่ม\n",
        "3. บริการต่างๆ\n",
        "4. ท่องเที่ยว\n",
        "5. สุขภาพและความงาม\n",
        "6. บันเทิง\n",
        "\n",
        "**เกณฑ์การตัดสินใจ (Decision Logic):**\n",
        "\n",
        "1. **กลุ่มสินค้า vs บริการ (Product vs Service Rule):**\n",
        "   - หากภาพเน้น \"ตัวสินค้า\" ที่หยิบจับได้, กล่องพัสดุ, ชั้นวางของ, หรือโพสต์ขายของออนไลน์ -> ให้ตอบ **\"ช้อปปิ้ง\"**\n",
        "   - หากภาพเน้น \"อุปกรณ์ให้บริการ\" หรือ \"สถานที่ให้บริการ\" -> ให้พิจารณาว่าเป็น **\"บริการต่างๆ\"** หรือ **\"สุขภาพและความงาม\"**\n",
        "\n",
        "2. **แยกแยะหมวด \"สุขภาพและความงาม\" vs \"ช้อปปิ้ง\":**\n",
        "   - **สุขภาพและความงาม:** การให้บริการต่อร่างกาย เช่น คลินิก, ร้านทำฟัน, ร้านนวด, ร้านทำผม, ร้านขายยา\n",
        "   - **ช้อปปิ้ง:** เพจขายเครื่องสำอาง/อาหารเสริม ที่เน้นรูปกล่องสินค้า, รีวิวสินค้า, การจัดส่งพัสดุ\n",
        "\n",
        "3. **บริบท Online vs Offline:**\n",
        "   - **Offline:** ป้ายชื่อร้าน, ตู้โชว์, โต๊ะอาหาร, เคาน์เตอร์บริการ\n",
        "   - **Online:** UI ของ Facebook/Line, คำว่า \"Inbox\", \"พร้อมส่ง\", \"ราคา xxx บาท\" -> ถ้าขายสินค้า ให้ตอบ **\"ช้อปปิ้ง\"**\n",
        "\n",
        "**คำจำกัดความเพิ่มเติมสำหรับ 6 หมวดหมู่:**\n",
        "- **อาหารและเครื่องดื่ม:** ร้านอาหาร, คาเฟ่, รถเข็นขายอาหาร, รูปจานอาหาร, เมนู\n",
        "- **บริการต่างๆ:** อู่ซ่อมรถ, ร้านซักรีด, ร้านรับส่งพัสดุ, ร้านถ่ายเอกสาร, ร้านรับเหมา\n",
        "- **ท่องเที่ยว:** โรงแรม, รีสอร์ท, บริษัททัวร์, ตั๋วเครื่องบิน\n",
        "- **บันเทิง:** ร้านเกม, คาราโอเกะ, ผับ/บาร์, สนามกีฬา\n",
        "- **สุขภาพและความงาม:** คลินิก, ร้านยา, ร้านนวด, สปา, ร้านเสริมสวย\n",
        "- **ช้อปปิ้ง:** ร้านสะดวกซื้อ, ร้านขายของชำ, ร้านเสื้อผ้า, ร้านขายวัสดุก่อสร้าง, ร้านขายมือถือ\n",
        "\n",
        "**ข้อบังคับ (Strict Rules):**\n",
        "1. ตอบกลับเป็น JSON เท่านั้น ห้ามมีข้อความอื่นปน\n",
        "2. Key ใน JSON ต้องเป็น \"Predicted_Category\" เท่านั้น\n",
        "3. Value ต้องเป็นตัวสะกดภาษาไทยที่กำหนดให้เป๊ะๆ\n",
        "\n",
        "**ตัวอย่างรูปแบบ JSON ที่ถูกต้อง:**\n",
        "{\"Predicted_Category\": \"ช้อปปิ้ง\"}\n",
        "\"\"\"\n",
        "\n",
        "predictions = []\n",
        "\n",
        "for index, row in df.iterrows():\n",
        "    shop_id = row['Shop_ID']\n",
        "    print(f\"\\n[{index+1}/{len(df)}] Processing Shop ID: {shop_id}\")\n",
        "\n",
        "    # --- Load images ---\n",
        "    img_paths = get_shop_images(shop_id, extract_path)\n",
        "    if not img_paths:\n",
        "        print(f\"  → No images found. Skipping.\")\n",
        "        predictions.append({\n",
        "            \"Shop_ID\":             shop_id,\n",
        "            \"Pred_Category\":       \"Error\",\n",
        "            \"Pred_Subcategory\":    \"No Image\",\n",
        "            \"Confidence\":          None,\n",
        "            \"Confidence_Category\": None,\n",
        "            \"Confidence_All\":      None,\n",
        "        })\n",
        "        continue\n",
        "\n",
        "    image_grid   = create_image_grid(img_paths)\n",
        "    image_inputs, video_inputs = process_vision_info([{\n",
        "        \"role\": \"user\",\n",
        "        \"content\": [{\"type\": \"image\", \"image\": image_grid},\n",
        "                    {\"type\": \"text\",  \"text\": system_prompt}],\n",
        "    }])\n",
        "\n",
        "    messages = [{\n",
        "        \"role\": \"user\",\n",
        "        \"content\": [\n",
        "            {\"type\": \"image\", \"image\": image_grid},\n",
        "            {\"type\": \"text\",  \"text\": system_prompt},\n",
        "        ],\n",
        "    }]\n",
        "\n",
        "    # ---------------------------------------------------------------\n",
        "    # Step A: Generation — ให้โมเดลสร้าง JSON ตอบ\n",
        "    # ---------------------------------------------------------------\n",
        "    text   = processor.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)\n",
        "    inputs = processor(\n",
        "        text=[text], images=image_inputs, videos=video_inputs,\n",
        "        padding=True, return_tensors=\"pt\",\n",
        "    ).to(\"cuda\")\n",
        "\n",
        "    with torch.no_grad():\n",
        "        generated_ids = model.generate(**inputs, max_new_tokens=256)\n",
        "\n",
        "    generated_ids_trimmed = [\n",
        "        out_ids[len(in_ids):]\n",
        "        for in_ids, out_ids in zip(inputs.input_ids, generated_ids)\n",
        "    ]\n",
        "    output_text = processor.batch_decode(\n",
        "        generated_ids_trimmed,\n",
        "        skip_special_tokens=True,\n",
        "        clean_up_tokenization_spaces=False,\n",
        "    )[0]\n",
        "\n",
        "    # Parse JSON\n",
        "    try:\n",
        "        match = re.search(r'\\{.*\\}', output_text, re.DOTALL)\n",
        "        if match:\n",
        "            result   = json.loads(match.group(0))\n",
        "            pred_cat = result.get(\"Predicted_Category\", \"Unknown\")\n",
        "            pred_sub = result.get(\"Predicted_Subcategory\", \"Unknown\")\n",
        "        else:\n",
        "            pred_cat = \"ParseError\"\n",
        "            pred_sub = output_text\n",
        "    except Exception as e:\n",
        "        pred_cat = \"Error\"\n",
        "        pred_sub = str(e)\n",
        "\n",
        "    # ---------------------------------------------------------------\n",
        "    # Step B: Confidence Scoring — score แต่ละ candidate ด้วย log-prob\n",
        "    # ---------------------------------------------------------------\n",
        "    try:\n",
        "        probs, conf_cat, confidence = compute_category_confidence(\n",
        "            model, processor, messages, image_inputs\n",
        "        )\n",
        "        confidence_all = {cat: float(p) for cat, p in zip(CATEGORIES, probs)}\n",
        "    except Exception as e:\n",
        "        print(f\"  [Warning] Confidence scoring failed: {e}\")\n",
        "        conf_cat, confidence, confidence_all = pred_cat, None, None\n",
        "\n",
        "    # Log\n",
        "    if confidence is not None:\n",
        "        print(f\"  → Generation : {pred_cat}\")\n",
        "        print(f\"  → Scoring    : {conf_cat}  (confidence={confidence:.3f})\")\n",
        "        if pred_cat != conf_cat:\n",
        "            print(f\"  [!] Generation vs Scoring mismatch!\")\n",
        "    else:\n",
        "        print(f\"  → Generation : {pred_cat}  (no confidence score)\")\n",
        "\n",
        "    predictions.append({\n",
        "        \"Shop_ID\":             shop_id,\n",
        "        \"Pred_Category\":       pred_cat,          # จาก Generation\n",
        "        \"Pred_Subcategory\":    pred_sub,\n",
        "        \"Confidence\":          confidence,         # max softmax prob [0, 1]\n",
        "        \"Confidence_Category\": conf_cat,           # category จาก Scoring (อาจต่างจาก Generation)\n",
        "        \"Confidence_All\":      json.dumps(confidence_all, ensure_ascii=False) if confidence_all else None,\n",
        "    })\n",
        "\n",
        "pred_df   = pd.DataFrame(predictions)\n",
        "result_df = pd.merge(df, pred_df, on=\"Shop_ID\", how=\"left\")\n",
        "print(\"\\n✅ Prediction pipeline complete.\")\n",
        "print(result_df[['Shop_ID', 'Pred_Category', 'Confidence', 'Confidence_Category']].head(10))"
      ],
